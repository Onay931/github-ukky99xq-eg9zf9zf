<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no">
<title>AI4Business South Africa — Investor Presentation 2026</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --red:#E8000A;
  --red-dark:#B80008;
  --red-low:rgba(232,0,10,.09);
  --red-xs:rgba(232,0,10,.04);
  --gold:#C9A840;
  --gold-light:#E8C84A;
  --black:#0A0A0A;
  --white:#FFFFFF;
  --off:#F9F9F9;
  --line:#E2E2E2;
  --line-xs:#EEEEEE;
  --text:#0F0F0F;
  --sub:#3A3A3A;
  --muted:#727272;
  --muted-xs:#AAAAAA;
  --max:#1B3D70;
  --max-low:rgba(27,61,112,.08);
  --sans:'IBM Plex Sans',sans-serif;
  --mono:'IBM Plex Mono',monospace;
}
html,body{width:100%;height:100%;font-family:var(--sans);background:var(--black);overflow:hidden;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}

/* PROGRESS */
#progress{position:fixed;top:0;left:0;height:2px;background:var(--red);transition:width .5s cubic-bezier(.4,0,.2,1);z-index:9999;box-shadow:0 0 12px rgba(232,0,10,.6)}

/* DECK */
.deck{width:100vw;height:100vh;position:relative}
.slide{position:absolute;inset:0;background:var(--white);display:flex;flex-direction:column;opacity:0;pointer-events:none;transition:opacity .38s cubic-bezier(.4,0,.2,1);overflow:hidden}
.slide.active{opacity:1;pointer-events:all;z-index:2}

/* HEADER */
.hdr{
  display:flex;align-items:center;justify-content:space-between;
  padding:12px 36px;
  border-bottom:1px solid var(--line);
  flex-shrink:0;min-height:56px;
  background:var(--white);
}
.hdr-left{display:flex;align-items:center;gap:12px}
.hdr-divider{width:1px;height:28px;background:var(--line)}
.hdr-name{font-family:var(--mono);font-size:9px;letter-spacing:.22em;color:var(--text);text-transform:uppercase;font-weight:600;line-height:1.3}
.hdr-name small{display:block;font-size:7.5px;letter-spacing:.18em;color:var(--muted);font-weight:400;margin-top:1px}
.hdr-right{display:flex;align-items:center;gap:16px}
.hdr-tag{font-family:var(--mono);font-size:8.5px;letter-spacing:.2em;color:var(--muted);text-transform:uppercase}
.hdr-slide-n{font-family:var(--mono);font-size:8.5px;letter-spacing:.12em;color:var(--red);font-weight:700}

/* BODY */
.body{flex:1;overflow-y:auto;overflow-x:hidden;scrollbar-width:thin;scrollbar-color:var(--line) transparent;padding-bottom:50px}
.body::-webkit-scrollbar{width:3px}
.body::-webkit-scrollbar-thumb{background:var(--line)}

/* NAV */
.nav{position:fixed;bottom:0;left:0;right:0;height:50px;background:rgba(255,255,255,.97);border-top:1px solid var(--line);display:flex;align-items:center;justify-content:center;z-index:9000;backdrop-filter:blur(16px)}
.nav-btn{background:none;border:none;cursor:pointer;color:var(--muted);font-family:var(--mono);font-size:8.5px;letter-spacing:.18em;text-transform:uppercase;padding:0 22px;height:50px;display:flex;align-items:center;gap:6px;transition:color .12s,background .12s;touch-action:manipulation;-webkit-tap-highlight-color:transparent;justify-content:center}
.nav-btn:hover{color:var(--red);background:var(--red-xs)}
.nav-btn svg{width:12px;height:12px;flex-shrink:0}
.nav-sep{width:1px;height:20px;background:var(--line)}
.nav-count{font-family:var(--mono);font-size:10.5px;color:var(--muted);letter-spacing:.12em;min-width:60px;text-align:center;padding:0 12px}
.nav-count span{color:var(--red);font-weight:700}
.nav-dots{display:flex;gap:5px;align-items:center;padding:0 16px}
.nav-dot{width:5px;height:5px;border-radius:50%;background:var(--line);transition:all .2s;cursor:pointer;border:none;padding:0}
.nav-dot.active{background:var(--red);transform:scale(1.3)}

/* LAYOUTS */
.two-col{display:grid;grid-template-columns:1fr 1fr;min-height:100%}
.col{padding:36px 40px 28px;display:flex;flex-direction:column;justify-content:center}
.col-l{border-right:1px solid var(--line)}
.sec-hdr{padding:28px 40px 20px;border-bottom:1px solid var(--line);flex-shrink:0}

/* TYPOGRAPHY */
.tag{font-family:var(--mono);font-size:8.5px;letter-spacing:.26em;color:var(--red);text-transform:uppercase;margin-bottom:10px}
h2{font-size:clamp(20px,2.6vw,36px);font-weight:700;color:var(--text);letter-spacing:-.025em;line-height:1.06;margin-bottom:12px}
.body-text{font-size:13px;color:var(--muted);line-height:1.72;margin-bottom:8px}
.body-text strong{color:var(--text);font-weight:600}
.rule{width:32px;height:2.5px;background:var(--red);margin-bottom:14px;flex-shrink:0}

/* STATS */
.stat-row{display:flex;gap:14px;margin-top:18px;flex-wrap:wrap}
.stat{border-top:2px solid var(--red);padding-top:9px;min-width:70px}
.stat-v{font-family:var(--mono);font-size:26px;font-weight:700;color:var(--text);letter-spacing:-.02em;line-height:1}
.stat-l{font-family:var(--mono);font-size:8px;letter-spacing:.15em;color:var(--muted);text-transform:uppercase;margin-top:4px}

/* CHART */
.chart-wrap{display:flex;flex-direction:column;padding:16px 18px;gap:7px}
.chart-cap{font-family:var(--mono);font-size:8px;letter-spacing:.14em;color:var(--muted);text-transform:uppercase}
.chart-box{width:100%;position:relative}
.legend{display:flex;gap:14px;flex-wrap:wrap}
.legend-item{display:flex;align-items:center;gap:4px;font-family:var(--mono);font-size:8px;letter-spacing:.1em;color:var(--muted);text-transform:uppercase}
.legend-dot{width:8px;height:3px;flex-shrink:0}

/* SCENARIO BADGES */
.scenario-row{display:flex;gap:6px;margin-bottom:8px}
.s-badge{font-family:var(--mono);font-size:7.5px;letter-spacing:.14em;text-transform:uppercase;padding:3px 8px;font-weight:700}
.s-badge.base{color:var(--white);background:var(--red)}
.s-badge.max{color:var(--white);background:var(--max)}

/* CARD GRID */
.card-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line)}
.card{background:var(--white);padding:28px 24px;display:flex;flex-direction:column;gap:10px;position:relative;overflow:hidden;transition:background .2s}
.card:hover{background:var(--red-xs)}
.card-num{position:absolute;top:-8px;right:-4px;font-family:var(--mono);font-size:80px;font-weight:700;color:rgba(0,0,0,.03);line-height:1;pointer-events:none}
.card-icon{width:34px;height:34px;border:1.5px solid var(--red);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.card-icon svg{width:15px;height:15px;stroke:var(--red);fill:none;stroke-width:1.6}
.card-tag{font-family:var(--mono);font-size:8px;letter-spacing:.2em;color:var(--red);text-transform:uppercase}
.card-title{font-size:14px;font-weight:700;color:var(--text);letter-spacing:-.01em;line-height:1.2}
.card-body{font-size:11.5px;color:var(--muted);line-height:1.65}

/* PILLARS */
.pillar-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--line)}
.pillar{background:var(--white);padding:32px 26px;display:flex;flex-direction:column;gap:9px;transition:background .2s}
.pillar:hover{background:var(--off)}
.pillar-n{font-family:var(--mono);font-size:44px;font-weight:700;color:rgba(0,0,0,.055);line-height:1;letter-spacing:-.04em}
.pillar-title{font-size:13.5px;font-weight:700;color:var(--text);border-top:2.5px solid var(--red);padding-top:10px;line-height:1.2}
.pillar-body{font-size:11.5px;color:var(--muted);line-height:1.65}

/* TABLE */
table{width:100%;border-collapse:collapse}
thead th{font-family:var(--mono);font-size:8px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);padding:0 0 10px;text-align:left;border-bottom:1px solid var(--line)}
thead th:not(:first-child){text-align:center}
tbody tr{border-bottom:1px solid var(--line-xs);transition:background .12s}
tbody tr:hover{background:var(--red-xs)}
tbody td{font-size:12px;color:var(--muted);padding:9px 0}
tbody td:not(:first-child){text-align:center}
.yes{display:inline-block;font-family:var(--mono);font-size:8px;letter-spacing:.1em;font-weight:700;color:var(--white);background:var(--red);padding:2px 7px}
.no{display:inline-block;font-family:var(--mono);font-size:8px;letter-spacing:.1em;font-weight:600;color:var(--muted);border:1px solid var(--line);padding:2px 7px}
.ltd{display:inline-block;font-family:var(--mono);font-size:8px;letter-spacing:.1em;font-weight:600;color:var(--muted);border:1px solid var(--line);padding:2px 7px}

/* PHASE */
.phase{display:flex;align-items:flex-start;gap:12px;padding:9px 0;border-bottom:1px solid var(--line-xs)}
.phase:first-child{border-top:1px solid var(--line-xs)}
.phase-n{font-family:var(--mono);font-size:8.5px;font-weight:700;color:var(--red);letter-spacing:.12em;min-width:18px;padding-top:2px}
.phase-title{font-size:12.5px;font-weight:600;color:var(--text);letter-spacing:-.01em;margin-bottom:1px}
.phase-body{font-size:11px;color:var(--muted);line-height:1.55}

/* NODE CARDS */
.node{border:1px solid var(--line);padding:14px 18px;display:grid;grid-template-columns:32px 1fr;gap:10px;align-items:center;margin-bottom:8px;transition:border-color .2s,background .2s}
.node:hover{border-color:var(--red);background:var(--red-xs)}
.node-n{font-family:var(--mono);font-size:18px;font-weight:700;color:rgba(0,0,0,.08);letter-spacing:-.04em}
.node-tag{font-family:var(--mono);font-size:7.5px;letter-spacing:.2em;color:var(--red);text-transform:uppercase;margin-bottom:3px}
.node-title{font-size:12.5px;font-weight:600;color:var(--text);margin-bottom:2px}
.node-spec{font-family:var(--mono);font-size:9.5px;color:var(--muted);letter-spacing:.04em}

/* KPI */
.kpi-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.kpi{border-top:2.5px solid var(--red);padding-top:9px}
.kpi-v{font-family:var(--mono);font-size:clamp(18px,2.2vw,28px);font-weight:700;color:var(--text);letter-spacing:-.02em;line-height:1}
.kpi-v.max{color:var(--max)}
.kpi-l{font-family:var(--mono);font-size:8px;letter-spacing:.15em;color:var(--muted);text-transform:uppercase;margin-top:3px}

/* RED BOX */
.red-box{border-left:3px solid var(--red);padding:11px 13px;background:var(--red-xs)}
.red-box-label{font-family:var(--mono);font-size:8px;letter-spacing:.18em;color:var(--red);text-transform:uppercase;margin-bottom:4px}
.red-box-text{font-size:11.5px;color:var(--muted);line-height:1.68}
.red-box-text strong{color:var(--text)}

/* INVESTMENT */
.invest-hero{background:var(--red);padding:20px 36px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
.invest-hero-stat{display:flex;flex-direction:column;gap:2px}
.invest-hero-val{font-family:var(--mono);font-size:clamp(18px,2.8vw,36px);font-weight:700;color:var(--white);letter-spacing:-.03em;line-height:1}
.invest-hero-label{font-family:var(--mono);font-size:8px;letter-spacing:.18em;color:rgba(255,255,255,.6);text-transform:uppercase}
.invest-hero-div{width:1px;height:36px;background:rgba(255,255,255,.18);flex-shrink:0}
.invest-body{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--line)}
.invest-col{background:var(--white);padding:24px 32px;display:flex;flex-direction:column;gap:10px}
.offer-row{display:flex;align-items:center;justify-content:space-between;padding:10px 13px;border:1px solid var(--line);transition:background .12s,border-color .12s}
.offer-row:hover{background:var(--red-xs);border-color:rgba(232,0,10,.2)}
.offer-label{font-family:var(--mono);font-size:8px;letter-spacing:.13em;color:var(--muted);text-transform:uppercase;margin-bottom:2px}
.offer-val{font-size:clamp(12px,1.5vw,17px);font-weight:700;color:var(--text);letter-spacing:-.01em}
.offer-val.red{color:var(--red)}
.offer-val.blue{color:var(--max)}
.capex-item{display:flex;gap:8px;align-items:flex-start;padding:8px 0;border-bottom:1px solid var(--line-xs)}
.capex-dot{width:4px;height:4px;background:var(--red);margin-top:5px;flex-shrink:0}
.capex-title{font-size:11.5px;font-weight:600;color:var(--text);margin-bottom:1px}
.capex-body{font-size:10.5px;color:var(--muted);line-height:1.55}

/* RETURN TABLE */
.rtable{width:100%;border-collapse:collapse;font-family:var(--mono)}
.rtable th{font-size:7.5px;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);padding:0 0 8px;text-align:right;border-bottom:1px solid var(--line)}
.rtable th:first-child{text-align:left}
.rtable td{padding:6px 0;text-align:right;border-bottom:1px solid var(--line-xs);color:var(--muted);font-size:10.5px}
.rtable td:first-child{text-align:left;color:var(--text);font-weight:600}
.rtable td.r{color:var(--red);font-weight:700}
.rtable td.b{color:var(--max);font-weight:700}
.rtable tr.tot td{border-top:2px solid var(--red);border-bottom:none;padding-top:8px;color:var(--text);font-weight:700;font-size:11.5px}
.rtable tr.tot td.r{color:var(--red)}
.rtable tr.tot td.b{color:var(--max)}

/* STREAMS */
.stream-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--line)}
.stream{background:var(--white);padding:26px 22px;display:flex;flex-direction:column;gap:8px;position:relative;overflow:hidden;transition:background .2s}
.stream:hover{background:var(--red-xs)}
.stream-bg{position:absolute;bottom:-6px;right:-3px;font-family:var(--mono);font-size:64px;font-weight:700;color:rgba(0,0,0,.035);line-height:1;pointer-events:none}
.stream-tag{font-family:var(--mono);font-size:8px;letter-spacing:.2em;color:var(--red);text-transform:uppercase}
.stream-title{font-size:14px;font-weight:700;color:var(--text);letter-spacing:-.01em;line-height:1.2}
.stream-range{font-family:var(--mono);font-size:9.5px;font-weight:600;color:var(--red)}
.stream-body{font-size:11.5px;color:var(--muted);line-height:1.65}
.stream-bar{height:2.5px;background:var(--line);margin-top:6px}
.stream-fill{height:100%;background:var(--red)}

/* CATALYSTS */
.cat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line)}
.cat{background:var(--white);padding:24px 22px;display:flex;flex-direction:column;gap:8px;position:relative;overflow:hidden;transition:background .2s}
.cat:hover{background:var(--red-xs)}
.cat-bg{position:absolute;top:-8px;right:-3px;font-family:var(--mono);font-size:64px;font-weight:700;color:rgba(232,0,10,.05);line-height:1;pointer-events:none}
.cat-icon{width:32px;height:32px;border:1.5px solid var(--red);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.cat-icon svg{width:14px;height:14px;stroke:var(--red);fill:none;stroke-width:1.6}
.cat-tag{font-family:var(--mono);font-size:7.5px;letter-spacing:.2em;color:var(--red);text-transform:uppercase}
.cat-title{font-size:13px;font-weight:700;color:var(--text);letter-spacing:-.01em;line-height:1.2}
.cat-body{font-size:11px;color:var(--muted);line-height:1.62}

/* ROADMAP */
.road-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);flex:1}
.road-phase{background:var(--white);padding:28px 24px;display:flex;flex-direction:column;gap:9px;position:relative;overflow:hidden;transition:background .2s}
.road-phase:hover{background:var(--red-xs)}
.road-num{position:absolute;bottom:-8px;right:-3px;font-family:var(--mono);font-size:68px;font-weight:700;color:rgba(0,0,0,.04);line-height:1}
.road-status{display:inline-block;font-family:var(--mono);font-size:7.5px;letter-spacing:.16em;text-transform:uppercase;padding:2px 8px;border:1px solid;width:fit-content}
.road-status.live{color:var(--red);border-color:var(--red)}
.road-status.next{color:var(--muted);border-color:var(--line)}
.road-status.future{color:var(--muted-xs);border-color:var(--line)}
.road-sub{font-family:var(--mono);font-size:8px;letter-spacing:.12em;color:var(--red);text-transform:uppercase}
.road-title{font-size:16px;font-weight:700;color:var(--text);letter-spacing:-.02em;line-height:1.15}
.road-body{font-size:11.5px;color:var(--muted);line-height:1.65}
.road-metrics{display:flex;flex-direction:column;gap:4px;margin-top:3px}
.road-metric{display:flex;justify-content:space-between;align-items:center;padding:5px 8px;background:var(--off)}
.road-ml{font-family:var(--mono);font-size:8px;letter-spacing:.1em;color:var(--muted);text-transform:uppercase}
.road-mv{font-family:var(--mono);font-size:11px;font-weight:700;color:var(--text)}

/* FOUNDER */
.founder-wrap{display:grid;grid-template-columns:260px 1fr;min-height:100%}
.founder-card{background:var(--black);padding:36px 28px;display:flex;flex-direction:column;gap:16px;position:relative;overflow:hidden}
.founder-card::after{content:'';position:absolute;top:0;right:0;bottom:0;width:3px;background:var(--red)}
.fc-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.025) 1px,transparent 1px);background-size:28px 28px;pointer-events:none}
.fc-photo{width:72px;height:72px;border:1.5px solid rgba(255,255,255,.12);background:rgba(255,255,255,.04);display:flex;align-items:center;justify-content:center;flex-shrink:0;position:relative}
.fc-photo svg{width:32px;height:32px;stroke:rgba(255,255,255,.35);fill:none;stroke-width:1.2}
.fc-name{font-size:18px;font-weight:700;color:var(--white);letter-spacing:-.02em;line-height:1.1}
.fc-role{font-family:var(--mono);font-size:8px;letter-spacing:.2em;color:var(--red);text-transform:uppercase;margin-top:3px;line-height:1.5}
.fc-creds{display:flex;flex-direction:column;gap:7px}
.fc-cred{display:flex;gap:8px;align-items:flex-start}
.fc-dot{width:4px;height:4px;background:var(--red);flex-shrink:0;margin-top:5px}
.fc-text{font-size:11px;color:rgba(255,255,255,.4);line-height:1.5}
.fc-contact{margin-top:auto;display:flex;flex-direction:column;gap:4px}
.fc-contact-item{display:flex;align-items:center;gap:6px}
.fc-contact-icon{width:14px;height:14px;flex-shrink:0}
.fc-contact-icon svg{width:14px;height:14px;stroke:var(--red);fill:none;stroke-width:1.4}
.fc-contact-text{font-family:var(--mono);font-size:8.5px;letter-spacing:.06em;color:rgba(255,255,255,.35)}
.founder-main{padding:36px 38px;display:flex;flex-direction:column;gap:16px;justify-content:center}
.cred-grid{display:grid;grid-template-columns:1fr 1fr;gap:9px}
.cred-card{border:1px solid var(--line);padding:14px 16px;transition:border-color .2s}
.cred-card:hover{border-color:var(--red)}
.cred-icon{font-family:var(--mono);font-size:7.5px;letter-spacing:.16em;color:var(--red);text-transform:uppercase;margin-bottom:4px}
.cred-title{font-size:12.5px;font-weight:600;color:var(--text);margin-bottom:3px}
.cred-body{font-size:11px;color:var(--muted);line-height:1.55}

/* COVER */
.cover-body{flex:1;display:flex;flex-direction:column;justify-content:center;padding:44px 72px;position:relative;overflow:hidden}
.cover-grid-bg{position:absolute;inset:0;background-image:linear-gradient(var(--line-xs) 1px,transparent 1px),linear-gradient(90deg,var(--line-xs) 1px,transparent 1px);background-size:60px 60px;opacity:.6;pointer-events:none}
.cover-accent{position:absolute;right:0;top:0;bottom:0;width:4px;background:var(--red)}
.cover-block{position:absolute;right:64px;bottom:64px;width:140px;height:140px;background:var(--red);opacity:.04}
.cover-block-2{position:absolute;right:100px;bottom:100px;width:70px;height:70px;border:1px solid var(--red);opacity:.07}
.cover-right-panel{position:absolute;top:0;right:4px;bottom:0;width:260px;border-left:1px solid var(--line);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0}
.cover-rstat{text-align:center;padding:20px 0;width:100%;border-bottom:1px solid var(--line)}
.cover-rstat:last-child{border-bottom:none}
.cover-rstat-v{font-family:var(--mono);font-size:clamp(16px,2vw,22px);font-weight:700;color:var(--text);letter-spacing:-.02em;line-height:1}
