  document.addEventListener('keydown',e=>{
    if(['ArrowRight','ArrowDown',' '].includes(e.key)){e.preventDefault();go(1);}
    if(['ArrowLeft','ArrowUp'].includes(e.key)){e.preventDefault();go(-1);}
  });
  let tx=0,ty=0;
  document.addEventListener('touchstart',e=>{tx=e.touches[0].clientX;ty=e.touches[0].clientY;},{passive:true});
  document.addEventListener('touchend',e=>{
    const dx=tx-e.changedTouches[0].clientX,dy=ty-e.changedTouches[0].clientY;
    if(Math.abs(dx)>Math.abs(dy)&&Math.abs(dx)>44) go(dx>0?1:-1);
  },{passive:true});

  upd();

  // CHART GLOBALS
  const RED='#E8000A',BLUE='#1B3D70',GR='rgba(0,0,0,.05)',MONO='IBM Plex Mono',SANS='IBM Plex Sans';
  const TT={backgroundColor:'#111',titleColor:'#fff',bodyColor:RED,borderColor:RED,borderWidth:1,padding:10,cornerRadius:0,titleFont:{family:MONO,size:10},bodyFont:{family:MONO,size:12,weight:'700'}};
  const AX={
    y:{grid:{color:GR},ticks:{color:'#888',font:{family:MONO,size:9}},border:{display:false}},
    x:{grid:{display:false},ticks:{color:'#222',font:{family:MONO,size:10}},border:{display:false}}
  };

  function initAdoption(){
    if(C.a) return;
    const cv=document.getElementById('adoptionChart');if(!cv)return;
    C.a=new Chart(cv,{type:'bar',data:{labels:['Individual AI Usage','SME Org. Deployment'],datasets:[{data:[60,8],backgroundColor:[RED,'rgba(107,107,107,.12)'],borderColor:[RED,'rgba(107,107,107,.25)'],borderWidth:1,borderRadius:0}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{...TT,callbacks:{label:c=>'  '+c.parsed.y+'%'}}},scales:{y:{...AX.y,beginAtZero:true,max:80,ticks:{...AX.y.ticks,callback:v=>v+'%'}},x:{...AX.x}},animation:{duration:900,easing:'easeOutQuart'}}});
  }

  function initPhase(){
    if(C.p) return;
    const cv=document.getElementById('phaseChart');if(!cv)return;
    C.p=new Chart(cv,{type:'bar',data:{labels:['Discovery','Design','Dev','Fine-Tune','Test','Deploy','Support'],datasets:[{data:[1,1,3,2,1,1,null],backgroundColor:[RED,RED,RED,RED,RED,RED,'rgba(0,0,0,.07)'],borderRadius:0,barThickness:10}]},options:{responsive:true,maintainAspectRatio:false,indexAxis:'y',plugins:{legend:{display:false},tooltip:{...TT,callbacks:{label:c=>'  ~'+c.parsed.x+' weeks'}}},scales:{x:{...AX.x,beginAtZero:true,grid:{color:GR},ticks:{...AX.x.ticks,callback:v=>v+'w'}},y:{...AX.y,grid:{display:false},ticks:{...AX.y.ticks,font:{family:MONO,size:8.5}}}},animation:{duration:700,easing:'easeOutQuart'}}});
  }

  function initVram(){
    if(C.v) return;
    const cv=document.getElementById('vramChart');if(!cv)return;
    C.v=new Chart(cv,{type:'bar',data:{labels:['RTX 5090 (Node 01)','MS-S1 Max (Node 02)'],datasets:[{data:[32,256],backgroundColor:[RED,RED],borderRadius:0,barThickness:24}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{...TT,callbacks:{label:c=>'  '+c.parsed.y+'GB VRAM'}}},scales:{y:{...AX.y,beginAtZero:true,ticks:{...AX.y.ticks,callback:v=>v+'GB'}},x:{...AX.x}},animation:{duration:700,easing:'easeOutQuart'}}});
  }

  function initFinancials(){
    if(C.r&&C.e&&C.cl) return;
    const yrs=['2026','2027','2028','2029','2030'];

    if(!C.r){
      const cv=document.getElementById('revenueChart');if(cv){
        const ctx=cv.getContext('2d');
        const g1=ctx.createLinearGradient(0,0,0,160);g1.addColorStop(0,'rgba(232,0,10,.13)');g1.addColorStop(1,'rgba(232,0,10,0)');
        const g2=ctx.createLinearGradient(0,0,0,160);g2.addColorStop(0,'rgba(27,61,112,.11)');g2.addColorStop(1,'rgba(27,61,112,0)');
        C.r=new Chart(ctx,{type:'line',data:{labels:yrs,datasets:[{label:'Base',data:[7.5,21,48,90,160],borderColor:RED,borderWidth:2.5,backgroundColor:g1,fill:true,tension:.4,pointBackgroundColor:RED,pointBorderColor:'#fff',pointBorderWidth:2,pointRadius:4,pointHoverRadius:6},{label:'Maximum',data:[11.5,33,77,145,248],borderColor:BLUE,borderWidth:2.5,backgroundColor:g2,fill:true,tension:.4,pointBackgroundColor:BLUE,pointBorderColor:'#fff',pointBorderWidth:2,pointRadius:4,pointHoverRadius:6}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{...TT,callbacks:{label:c=>'  '+c.dataset.label+': R'+c.parsed.y+'M'}}},scales:{y:{...AX.y,beginAtZero:true,ticks:{...AX.y.ticks,callback:v=>'R'+v+'M'}},x:{...AX.x}},animation:{duration:950,easing:'easeOutQuart'}}});
      }
    }

    if(!C.e){
      const cv=document.getElementById('ebitdaChart');if(cv){
        C.e=new Chart(cv,{type:'bar',data:{labels:yrs,datasets:[{label:'Base %',data:[25,32,38,42,45],backgroundColor:RED,borderRadius:0,barThickness:12},{label:'Max %',data:[28,37,45,50,53],backgroundColor:BLUE,borderRadius:0,barThickness:12}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{...TT,callbacks:{label:c=>'  '+c.dataset.label+': '+c.parsed.y+'%'}}},scales:{y:{...AX.y,beginAtZero:true,max:62,ticks:{...AX.y.ticks,callback:v=>v+'%'}},x:{...AX.x}},animation:{duration:800,easing:'easeOutQuart'}}});
      }
    }

    if(!C.cl){
      const cv=document.getElementById('clientChart');if(cv){
        C.cl=new Chart(cv,{type:'line',data:{labels:yrs,datasets:[{label:'Base',data:[25,60,120,200,320],borderColor:RED,borderWidth:2,tension:.35,pointBackgroundColor:RED,pointBorderColor:'#fff',pointBorderWidth:2,pointRadius:3.5,fill:false},{label:'Maximum',data:[38,95,190,320,500],borderColor:BLUE,borderWidth:2,tension:.35,pointBackgroundColor:BLUE,pointBorderColor:'#fff',pointBorderWidth:2,pointRadius:3.5,fill:false}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{...TT,callbacks:{label:c=>'  '+c.dataset.label+': '+c.parsed.y+' clients'}}},scales:{y:{...AX.y,beginAtZero:true},x:{...AX.x}},animation:{duration:850,easing:'easeOutQuart'}}});
      }
    }
  }
})();
</script>
</body>
</html>